# .env.example
# Copy this file to .env and fill in your actual credentials
# DO NOT commit .env to version control — it's in .gitignore

# ── Airtable ──────────────────────────────────────────────────────────────
# Get from: https://airtable.com/create/tokens
# Scopes: data.records:read, data.records:write, schema.bases:read, schema.bases:write
AIRTABLE_API_KEY=pat_YOUR_TOKEN_HERE
AIRTABLE_BASE_ID=app_YOUR_BASE_ID_HERE

# ── Shopify ───────────────────────────────────────────────────────────────
# Store URL (no https://)
SHOPIFY_STORE_URL=your-store.myshopify.com

# Admin API token — from Shopify Admin → Apps → Develop apps → your app
SHOPIFY_ADMIN_API_TOKEN=shpat_YOUR_TOKEN_HERE

# Webhook signing secret — from Shopify Admin → Settings → Notifications → Webhooks
SHOPIFY_WEBHOOK_SECRET=YOUR_WEBHOOK_SECRET_HERE

# API version
SHOPIFY_API_VERSION=2026-01

# ── Anthropic ─────────────────────────────────────────────────────────────
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-YOUR_API_KEY_HERE

# ── Server ────────────────────────────────────────────────────────────────
# Your public-facing booking URL
BASE_URL=https://booking.yourdomain.com

# ── Admin ─────────────────────────────────────────────────────────────────
# Secret key for /admin/calendar endpoint (set to a strong random string)
ADMIN_SECRET=your-secret-key-here
